@model IEnumerable<ZoologicalStore.Models.Product>

@{
    ViewData["Title"] = "Товары";
}

<h1>Товары</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить товар</a>
</p>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Поиск...">
                <button class="btn btn-outline-secondary" type="submit">Найти</button>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="btn-group float-end">
            <a asp-action="Index" class="btn btn-outline-secondary">Все</a>
            <a asp-action="Index" asp-route-category="Собаки" class="btn btn-outline-secondary">Собаки</a>
            <a asp-action="Index" asp-route-category="Кошки" class="btn btn-outline-secondary">Кошки</a>
            <a asp-action="Index" asp-route-category="Птицы" class="btn btn-outline-secondary">Птицы</a>
            <a asp-action="Index" asp-route-category="Рыбы" class="btn btn-outline-secondary">Рыбы</a>
        </div>
    </div>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@Html.DisplayFor(modelItem => item.Name)</h5>
                    <h6 class="card-subtitle mb-2 text-muted">@Html.DisplayFor(modelItem => item.Category)</h6>
                    <p class="card-text">@Html.DisplayFor(modelItem => item.Description)</p>
                    <p class="card-text"><strong>Цена:</strong> @Html.DisplayFor(modelItem => item.Price) ₽</p>
                    <p class="card-text"><strong>В наличии:</strong> @Html.DisplayFor(modelItem => item.StockQuantity) шт.</p>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Подробнее</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редактировать</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Удалить</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>